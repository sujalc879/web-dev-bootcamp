generator client {
	provider = "prisma-client"
	output = "./generated"
	engineType = "client"
	runtime = "bun"
}

datasource db {
	provider = "postgresql"
}

model User { 
	id        Int     @id @default(autoincrement()) 
	username  String  @unique
	password  String
  todo      Todo[]
}

model Todo {
  id        Int     @id @default(autoincrement())
  userId    Int
  title     String
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}